   "source": [
    "class Person:\n",
    "    def __init__(self, name, age):\n",
    "        self.name = name\n",
    "        self.age = age\n",
    "\n",
    "    @classmethod\n",
    "    def from_string(cls, data):\n",
    "        name, age = data.split(\"-\")\n",
    "        return cls(name, int(age))\n",
    "\n",
    "\n",
    "p = Person.from_string(\"Nam-20\")\n",
    "print(p.name, p.age)"
   ],
